# ── Server ────────────────────────────────────────────────
PORT=3000

# ── Stripe ────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# From: stripe listen --forward-to localhost:3000/api/stripe/webhook
# (different value for dev vs prod)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SMTP (e.g. Postmark, Resend, SendGrid) ────────────────
# Leave blank to disable email sending (server will still work)
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-api-token
SMTP_PASS=your-api-token
EMAIL_FROM=RevPilot <support@revpilot.net>

# ── Admin ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace-with-a-long-random-secret
ADMIN_EMAIL=your@email.com
